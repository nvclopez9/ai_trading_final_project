# --- Selector de proveedor LLM ---------------------------------------------
# "ollama"     -> usa modelo local vía Ollama (variables OLLAMA_*).
# "openrouter" -> usa OpenRouter (modelos remotos, gratis o de pago).
# Si OPENROUTER_API_KEY está vacía y eliges openrouter, hace fallback a ollama.
LLM_PROVIDER=ollama

# --- Ollama (local) --------------------------------------------------------
OLLAMA_MODEL=gemma3:4b
OLLAMA_HOST=http://localhost:11434

# --- OpenRouter (remoto, opcional) -----------------------------------------
# Crea una API key gratis en https://openrouter.ai/keys y pégala aquí.
# Modelo recomendado (gratis, soporta tool-calling y suele tener cuota disponible):
# openai/gpt-oss-20b:free.
# Alternativas free con tools (a veces rate-limited upstream):
#   meta-llama/llama-3.3-70b-instruct:free
#   qwen/qwen3-next-80b-a3b-instruct:free
#   z-ai/glm-4.5-air:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free
# Cabeceras opcionales para el ranking público de OpenRouter (no obligatorias).
OPENROUTER_SITE_URL=http://localhost:8501
OPENROUTER_APP_NAME=Bot de Inversiones

# --- Persistencia ----------------------------------------------------------
DB_PATH=data/portfolio.db
CHROMA_DIR=chroma

# --- Embeddings (siempre Ollama, independiente del LLM) --------------------
# Default: nomic-embed-text (768 dim, ligero).
# Alternativa validada: mxbai-embed-large (1024 dim, más precisa pero más pesada).
# Debe estar descargado en Ollama antes de ingestar: `ollama pull <modelo>`.
EMBEDDINGS_MODEL=nomic-embed-text
