# --- NVIDIA NIM (LLM principal) -----------------------------------------------
# Crea o consigue tu API key en https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_MODEL=moonshotai/kimi-k2-instruct

# --- Embeddings RAG (Ollama local) --------------------------------------------
# Ollama se usa SOLO para los embeddings del RAG, no como LLM.
# Asegúrate de tener el modelo descargado: ollama pull nomic-embed-text
# Alternativa más precisa (más pesada): mxbai-embed-large
OLLAMA_HOST=http://localhost:11434
EMBEDDINGS_MODEL=nomic-embed-text

# --- Logging ------------------------------------------------------------------
# debug   → llamadas a tools, APIs y tiempos de respuesta
# info    → mensajes de estado generales
# warning → solo errores y advertencias (recomendado)
LOG_LEVEL=warning

# --- Persistencia -------------------------------------------------------------
DB_PATH=data/portfolio.db
CHROMA_DIR=chroma
